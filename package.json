{
  "name": "tuify",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node --watch src/server/index.js",
    "dev:full": "concurrently -n \"server,vite\" -c \"cyan,magenta\" \"npm run server\" \"npm run dev\"",
    "db:migrate": "node src/server/db/migrate.js",
    "build": "vite build",
    "start": "NODE_ENV=production node src/server/index.js",
    "preview": "vite preview",
    "check:arch": "node scripts/check-architecture.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "gif.js": "^0.2.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "sql.js": "^1.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.1.2",
    "vite": "^4.0.0"
  }
}
